# Model provider key — required to RUN the agent (not needed to build or test).
ANTHROPIC_API_KEY=

# Override the default model. Format: "provider/model-name".
AI_MODEL=anthropic/claude-sonnet-4-5

# The Go API (apps/api) that the agent's tools call.
API_BASE_URL=http://localhost:3000

# Optional service bearer token for authenticated API calls.
API_SERVICE_TOKEN=
