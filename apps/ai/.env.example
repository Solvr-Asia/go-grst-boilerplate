# Anthropic API key — required to RUN agents (not needed to build or test).
ANTHROPIC_API_KEY=

# Anthropic model id (LangChain ChatAnthropic). Default: claude-opus-4-8.
AI_MODEL=claude-opus-4-8
AI_MAX_TOKENS=8192

# HTTP server port.
PORT=4111

# The Go API (apps/api) that the agent's tools and workflows call.
API_BASE_URL=http://localhost:3000

# Optional service bearer token for authenticated API calls.
API_SERVICE_TOKEN=

# Where LangGraph persists thread state: memory (dev) | postgres (durable).
CHECKPOINTER=memory
# Required when CHECKPOINTER=postgres — reuse apps/api's Postgres.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/veemon_db
